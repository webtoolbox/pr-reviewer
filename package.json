{
  "name": "diff-reviewer",
  "version": "1.1.0",
  "description": "A macOS desktop app for reviewing GitHub PR diffs with line-level commenting, file-level comments, and AI agent integration.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "electron test.js",
    "build": "electron-builder --mac",
    "build:dir": "electron-builder --mac --dir"
  },
  "keywords": [
    "code-review",
    "diff-viewer",
    "pull-request",
    "electron",
    "github",
    "diff2html"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^37.2.6",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "diff2html": "^3.4.52",
    "marked": "^18.0.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/webtoolbox/diff-reviewer.git"
  },
  "bugs": {
    "url": "https://github.com/webtoolbox/diff-reviewer/issues"
  },
  "homepage": "https://github.com/webtoolbox/diff-reviewer#readme",
  "build": {
    "appId": "com.webtoolbox.diff-reviewer",
    "productName": "Diff Reviewer",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icon.png",
      "fileAssociations": [
        {
          "ext": "diff",
          "name": "Diff File",
          "mimeType": "text/x-diff",
          "role": "Viewer"
        },
        {
          "ext": "patch",
          "name": "Patch File",
          "mimeType": "text/x-patch",
          "role": "Viewer"
        }
      ]
    },
    "fileAssociations": [
      {
        "ext": "diff",
        "name": "Diff File",
        "mimeType": "text/x-diff",
        "role": "Viewer"
      },
      {
        "ext": "patch",
        "name": "Patch File",
        "mimeType": "text/x-patch",
        "role": "Viewer"
      }
    ]
  }
}
